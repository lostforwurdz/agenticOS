[Unit]
Description=Run AgenticOS memory-consolidation agent nightly at 23:00 local time
Documentation=file://%h/agenticOS/scripts/memory-consolidation-cron.py

[Timer]
# 23:00 every day, local time. Leaves a 30-min gap before stack-health at 23:30
# per ~/.claude/CLAUDE.md scheduled-agents table.
OnCalendar=*-*-* 23:00:00
# Catch up after suspended/missed runs (laptop sleep).
Persistent=true
# Slight randomization so multiple machines don't hit dolt remote at the
# same instant.
RandomizedDelaySec=60
Unit=memory-consolidation.service

[Install]
WantedBy=timers.target
